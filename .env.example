
# SQLite Database (Legacy)
DATABASE_URL="sqlite.db"

# PostgreSQL Database (Supabase / Production)
# Make sure to replace [YOUR-PASSWORD] with the actual password you generated!
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your_project.supabase.co:5432/postgres

# JWT Secrets
JWT_SECRET=your_64_char_random_string_here
JWT_REFRESH_SECRET=another_64_char_random_string_here

# Encryption Key (Must be 32 bytes / 64 hex characters)
ENCRYPTION_KEY=generate_a_64_char_hex_string_here

# Razorpay (Placeholder)
RAZORPAY_KEY_ID="rzp_test_placeholder"
RAZORPAY_KEY_SECRET="rzp_test_secret_placeholder"

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Upstox Credentials
UPTOX_API_KEY=your_uptox_api_key
UPTOX_API_SECRET=your_uptox_api_secret
UPTOX_REDIRECT_URI=http://localhost:3000/auth/callback

# Frontend Application URL (Used for postMessage security)
VITE_APP_URL=http://localhost:5173

# Upstox Deep Links / Web URLs for Funds
# Replace these with your partner-approved or documented URLs if different.
VITE_UPSTOX_PAYIN_URL=https://login.upstox.com/add-funds
VITE_UPSTOX_PAYOUT_URL=https://login.upstox.com/funds/withdraw