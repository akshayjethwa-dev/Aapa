# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# DATABASE & CACHE (AWS Infrastructure)
# ==========================================
# Format: postgres://<master_username>:<master_password>@<rds_endpoint>:5432/<db_name>
DATABASE_URL=your_Database_URL
REDIS_URL=your_Redis_URL

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
JWT_SECRET=your_jwt_Secret
JWT_REFRESH_SECRET=your_JWT_Refresh_secret
ENCRYPTION_KEY=your_encryption_key

# ==========================================
# FRONTEND & ROUTING
# ==========================================
# Replace with your actual EC2 IP or custom domain
VITE_APP_URL=your_vite_app_URL
VITE_APP_URL=your_Vite_App_URL

# ==========================================
# UPSTOX API CREDENTIALS
# ==========================================
UPTOX_API_KEY=your_uptox_Api_key
UPTOX_API_SECRET=your_uptox_API_Sectrt

# Replace with your actual EC2 IP or custom domain
UPTOX_REDIRECT_URI=your_uptox_redirect_URI
VITE_UPSTOX_PAYIN_URL=your_VITE_UPSTOX_PAYIN_URL
VITE_UPSTOX_PAYOUT_URL=your_VITE_UPSTOX_PAYOUT_URL

# ==========================================
# FIREBASE CONFIGURATION
# ==========================================
VITE_FIREBASE_API_KEY=your_VITE_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your_VITE_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=your_VITE_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=your_VITE_FIREBASE_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=your_VITE_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=your_VITE_FIREBASE_APP_ID

# ==========================================
# PAYMENT GATEWAY (RAZORPAY)
# ==========================================
RAZORPAY_KEY_ID="rzp_test_placeholder"
RAZORPAY_KEY_SECRET="rzp_test_secret_placeholder"

# ==========================================
# ADMIN & MISC SERVICES
# ==========================================
ADMIN_EMAIL=your_ADMIN_EMAIL
ADMIN_PASSWORD=your_ADMIN_PASSWORD
NEWSDATA_API_KEY=your_NEWSDATA_API_KEY